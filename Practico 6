6) Ecuación cuadrática (todos los casos)
#include <iostream>
#include <cmath>
using namespace std;

int main() {
    float a, b, c, D;

    cout << "Ingrese a, b, c: ";
    cin >> a >> b >> c;

    D = b*b - 4*a*c;

    if (D > 0) {
        cout << "Dos soluciones reales\n";
        cout << (-b + sqrt(D))/(2*a) << endl;
        cout << (-b - sqrt(D))/(2*a) << endl;
    } else if (D == 0) {
        cout << "Una solucion real\n";
        cout << -b/(2*a);
    } else {
        cout << "No hay soluciones reales";
    }

    return 0;
}


7) Sistema de ecuaciones
#include <iostream>
using namespace std;

int main() {
    float a,b,c,d,e,f,det,x,y;

    cout << "Ingrese a,b,c,d,e,f: ";
    cin >> a >> b >> c >> d >> e >> f;

    det = a*e - b*d;

    if (det != 0) {
        x = (c*e - b*f) / det;
        y = (a*f - c*d) / det;

        cout << "Solucion unica:\n";
        cout << "X=" << x << " Y=" << y;
    } else {
        cout << "No hay solucion unica";
    }

    return 0;
}



