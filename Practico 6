4) Tiempo transcurrido
#include <iostream>
using namespace std;

int main() {
    int h1, m1, s1, h2, m2, s2;
    int t1, t2, diff;

    cout << "Hora 1 (h m s): ";
    cin >> h1 >> m1 >> s1;

    cout << "Hora 2 (h m s): ";
    cin >> h2 >> m2 >> s2;

    t1 = h1 * 3600 + m1 * 60 + s1;
    t2 = h2 * 3600 + m2 * 60 + s2;

    diff = t2 - t1;

    int h = diff / 3600;
    int m = (diff % 3600) / 60;
    int s = diff % 60;

    cout << "Tiempo transcurrido: "
         << h << ":" << m << ":" << s << endl;

    return 0;
}


