1) Costo de envio de carta 
#include <iostream>
using namespace std;

int main() {
    float P, costo;

    cout << "Ingrese el peso de la carta en gramos: ";
    cin >> P;

    if (P > 0 && P < 50)
        costo = 1.50;
    else if (P > 50 && P <= 100)
        costo = 4.00;
    else if (P > 100 && P <= 200)
        costo = 6.00;
    else if (P > 200 && P <= 350)
        costo = 10.50;
    else if (P > 350 && P <= 500)
        costo = 15.00;
    else {
        cout << "NO PUEDE ENVIAR COMO CARTA" << endl;
        return 0;
    }

    cout << "Costo de envio: Bs. " << costo << endl;

    return 0;
}


2) Ecuación cuadrática (básico)
#include <iostream>
#include <cmath>
using namespace std;

int main() {
    float a, b, c, x1, x2, D;

    cout << "Ingrese a, b, c: ";
    cin >> a >> b >> c;

    D = pow(b, 2) - 4 * a * c;

    x1 = (-b + sqrt(D)) / (2 * a);
    x2 = (-b - sqrt(D)) / (2 * a);

    cout << "x1 = " << x1 << endl;
    cout << "x2 = " << x2 << endl;

    return 0;
}


