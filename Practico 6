9) Áreas con menú
#include <iostream>
using namespace std;

int main() {
    int op;
    float L, R, B, H;

    cout << "1. Cuadrado\n2. Circulo\n3. Triangulo\n";
    cin >> op;

    switch(op) {
        case 1:
            cin >> L;
            cout << "Area = " << L*L;
            break;
        case 2:
            cin >> R;
            cout << "Area = " << 3.1416*R*R;
            break;
        case 3:
            cin >> B >> H;
            cout << "Area = " << (B*H)/2;
            break;
    }

    return 0;
}


10) Nota final (con repetición)
#include <iostream>
using namespace std;

int main() {
    float p1, p2, practico, final, nf;
    int faltas;
    char op;

    do {
        cout << "Parcial 1: "; cin >> p1;
        cout << "Parcial 2: "; cin >> p2;
        cout << "Practico: "; cin >> practico;
        cout << "Final: "; cin >> final;
        cout << "Faltas: "; cin >> faltas;

        if (faltas > 9)
            final = 0;

        nf = (p1+p2)/2 * 0.4 + practico*0.2 + final*0.4;

        cout << "Nota final: " << nf << endl;

        if (nf >= 51)
            cout << "APROBADO\n";
        else
            cout << "REPROBADO\n";

        cout << "Otro alumno? (s/n): ";
        cin >> op;

    } while(op == 's');

    return 0;
}
