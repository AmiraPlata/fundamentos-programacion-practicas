Ejercicio 9)
#include <iostream>
#include <cmath>
using namespace std;

int BINARIO(int bin)
{
    int dec = 0;
    int i = 0;
    int r;

    while(bin > 0)
    {
        r = bin % 10;

        dec += r * pow(2, i);

        bin /= 10;
        i++;
    }

    return dec;
}

int main()
{
    int bin;

    cin >> bin;

    cout << "Decimal: "
         << BINARIO(bin);

    return 0;
}





