Ejercicio 14)
#include <iostream>
#include <cmath>
using namespace std;

int DIAS(int d, int m, int a)
{
    return d + (m * 30) + (a * 365);
}

int DIFERENCIA(int d1, int m1, int a1,
               int d2, int m2, int a2)
{
    return abs(DIAS(d2,m2,a2)
         - DIAS(d1,m1,a1));
}

int main()
{
    int d1, m1, a1;
    int d2, m2, a2;

    cin >> d1 >> m1 >> a1;
    cin >> d2 >> m2 >> a2;

    cout << "Dias: "
         << DIFERENCIA(d1,m1,a1,
                       d2,m2,a2);

    return 0;
}
