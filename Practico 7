Ejercicio 3)
#include <iostream>
#include <cmath>
using namespace std;

long long FAC(int n)
{
    long long f = 1;

    for(int i = 1; i <= n; i++)
    {
        f *= i;
    }

    return f;
}

double SERIE(int x, int N)
{
    double S = 0;

    for(int i = 1; i <= N; i++)
    {
        S += pow(x, i) / FAC(i);
    }

    return S;
}

int main()
{
    int x, N;

    cin >> x >> N;

    cout << "Resultado: " << SERIE(x, N);

    return 0;
}







Ejercicio 4)
#include <iostream>
#include <cmath>
using namespace std;

long long FAC(int n)
{
    long long f = 1;

    for(int i = 1; i <= n; i++)
    {
        f *= i;
    }

    return f;
}

double SERIE(int x, int N)
{
    double S = 0;
    int signo = 1;

    for(int i = 1; i <= N; i += 2)
    {
        S += signo * (pow(x, i) / FAC(i));
        signo *= -1;
    }

    return S;
}

int main()
{
    int x, N;

    cin >> x >> N;

    cout << "Resultado: " << SERIE(x, N);

    return 0;
}




Ejercicio 5)
#include <iostream>
using namespace std;

void SISTEMA(double A, double B, double C,
             double D, double E, double F,
             double &X, double &Y)
{
    double det;

    det = A * E - B * D;

    X = (B * F - C * E) / det;
    Y = (C * D - A * F) / det;
}

int main()
{
    double A, B, C, D, E, F;
    double X, Y;

    cin >> A >> B >> C;
    cin >> D >> E >> F;

    SISTEMA(A, B, C, D, E, F, X, Y);

    cout << "X = " << X << endl;
    cout << "Y = " << Y;

    return 0;
}




