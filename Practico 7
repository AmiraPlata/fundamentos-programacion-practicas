void ECUACION(double a, double b, double c)
{
    double d, x1, x2;

    d = b*b - 4*a*c;

    if(d > 0)
    {
        x1 = (-b + sqrt(d)) / (2*a);
        x2 = (-b - sqrt(d)) / (2*a);

        cout << "Raices reales:" << endl;
        cout << x1 << endl;
        cout << x2;
    }
    else if(d == 0)
    {
        x1 = -b / (2*a);

        cout << "Raiz doble: "
             << x1;
    }
    else
    {
        cout << "Raices complejas";
    }
}

int main()
{
    double a, b, c;

    cin >> a >> b >> c;

    ECUACION(a, b, c);

    return 0;
